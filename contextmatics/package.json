{
  "name": "contextmatic",
  "version": "1.0.0",
  "description": "AI-powered content repurposing platform for creators and marketers",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-with-check": "npm run type-check && vite build",
