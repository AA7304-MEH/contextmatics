# ContextMatic Production Environment Variables
# RENAME TO .env.production AND FILL WITH REAL KEYS

# PAYMENTS (Production Keys)
# https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx

# https://developer.paypal.com/dashboard/
VITE_PAYPAL_CLIENT_ID=ATxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AUTHENTICATION (Clerk Production)
# https://dashboard.clerk.com/ -> API Keys -> Production
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI SERVICES
# https://makersuite.google.com/app/apikey (Ensure quota is sufficient)
VITE_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PRODUCTION SETTINGS
VITE_ENABLE_PAYMENT_TESTING=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_MAINTENANCE_MODE=false
