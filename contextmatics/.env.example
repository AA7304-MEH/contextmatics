# ContextMatic — Environment Variables
# Copy this file to .env and fill in your real API keys.
# All variables prefixed with VITE_ are exposed to the browser.

# ─────────────────────────────────────────────
# REQUIRED — Supabase (Database & Auth backend)
# ─────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# ─────────────────────────────────────────────
# REQUIRED — Clerk (Authentication)
# ─────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_key_here

# ─────────────────────────────────────────────
# REQUIRED — Payments
# ─────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_here

# Get from: https://developer.paypal.com → My Apps & Credentials
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# ─────────────────────────────────────────────
# REQUIRED — AI Services
# ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# OPTIONAL — Feature Flags
# ─────────────────────────────────────────────
VITE_ENABLE_PAYMENT_TESTING=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_MAINTENANCE_MODE=false