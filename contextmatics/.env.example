# ContextMatic Environment Variables for Vercel Deployment
# Copy this file to .env.local for local development
# Add these variables to your Vercel dashboard under Project Settings > Environment Variables

# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# Razorpay Payment Gateway (Get from https://dashboard.razorpay.com/)
# For testing: Use test key from Razorpay dashboard
# For production: Use live key from Razorpay dashboard
VITE_RAZORPAY_KEY_ID=rzp_test_your_test_key_here

# PayPal Integration (Get from https://developer.paypal.com/)
# Create an app in PayPal Developer Dashboard to get Client ID
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Google Gemini AI API (Get from https://makersuite.google.com/app/apikey)
# This is required for content generation features
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# OPTIONAL ENVIRONMENT VARIABLES (for enhanced features)
# =============================================================================

# Webhook URL (if you have a backend server for handling webhooks)
VITE_WEBHOOK_URL=https://your-backend-server.com/webhook

# Analytics URL (if you have a backend server for analytics)
VITE_ANALYTICS_URL=https://your-backend-server.com/analytics

# Google Analytics (Get from https://analytics.google.com/)
VITE_GA_ID=G-XXXXXXXXXX

# Mixpanel Analytics (Get from https://mixpanel.com/)
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here

# Sentry Error Tracking (Get from https://sentry.io/)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# FEATURE FLAGS (set to 'true' to enable)
# =============================================================================

# Enable payment testing mode (shows test payment options)
VITE_ENABLE_PAYMENT_TESTING=false

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=true

# Enable error reporting to Sentry
VITE_ENABLE_ERROR_REPORTING=false

# Enable maintenance mode (shows maintenance page)
VITE_MAINTENANCE_MODE=false

# =============================================================================
# HOW TO SET THESE IN VERCEL DASHBOARD
# =============================================================================
#
# 1. Go to your Vercel project dashboard
# 2. Navigate to "Settings" tab
# 3. Click on "Environment Variables" in the left sidebar
# 4. Click "Add New" button
# 5. Add each variable:
#    - Name: VITE_RAZORPAY_KEY_ID
#    - Value: rzp_test_your_actual_key
# 6. Repeat for all required variables
# 7. Click "Save" and redeploy
#
# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# ⚠️  IMPORTANT SECURITY INFORMATION:
#
# 1. Never commit your .env.local file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use different keys for development and production
# 4. Monitor your API usage in the respective dashboards
# 5. Enable 2FA on all your accounts
#
# For production deployment:
# - Use live/production API keys (not test keys)
# - Set up proper webhook endpoints
# - Enable proper monitoring and alerting
#
# =============================================================================