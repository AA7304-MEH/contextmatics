# Netlify redirects for HashRouter
# Since we're using HashRouter, we don't need complex SPA fallbacks
# HashRouter handles routing client-side with # in URLs

# API routes (if you add them later)
/api/*  /.netlify/functions/:splat  200

# Sitemap and robots.txt
/sitemap.xml  /sitemap.xml  200
/robots.txt   /robots.txt   200