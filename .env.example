# ContextMatic — Definitive Production Environment Configuration
# Copy this to .env.local for local development.
# IMPORTANT: All variables prefixed with NEXT_PUBLIC_ are accessible to the client browser.

# ============================================================
# 1. CORE INFRASTRUCTURE — SUPABASE (Database & Auth)
# ============================================================
# URL of your Supabase project (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public/Anonymous Key for client-side API requests
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (Keep private, Server-side ONLY)
# Used for administrative tasks (e.g., credit management) and bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# 2. AI SERVICES (Content & Media Generation)
# ============================================================
# Google Gemini (Primary API for text generation)
GEMINI_API_KEY=your-google-gemini-key

# Replicate (Primary API for Image, Logo, and Video generation)
REPLICATE_API_TOKEN=your-replicate-token

# OpenAI (Secondary/Fallback Provider)
OPENAI_API_KEY=your-openai-key

# HuggingFace (Optional)
HUGGINGFACE_API_KEY=your-huggingface-key

# Ollama (Local AI testing - Optional)
# OLLAMA_HOST=http://localhost:11434

# ============================================================
# 3. PAYMENT GATEWAYS (Subscriptions & Credits)
# ============================================================
# Razorpay (Core regional payment gateway)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...  # Replace with 'rzp_live_' for production
RAZORPAY_KEY_SECRET=your-razorpay-secret

# PayPal (International payment support)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-id
PAYPAL_SECRET=your-paypal-secret

# Stripe (Fallback/Secondary)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# 4. SOCIAL DISTRIBUTION — AYRSHARE
# ============================================================
# Required for Content Calendar and automated social publishing.
AYRSHARE_API_KEY=your-ayrshare-api-key

# ============================================================
# 5. RUNTIME INFRASTRUCTURE (Redis & Sentry)
# ============================================================
# Upstash Redis (Required for API Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Sentry (Error monitoring and reporting)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn.ingest.sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Mixpanel (User Behavior Analytics)
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# ============================================================
# 6. APPLICATION CONFIGURATION & FLAGS
# ============================================================
# Base URL for the full site
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Feature Toggle: Set to 'false' in production to disable internal test routes.
NEXT_PUBLIC_ENABLE_PAYMENT_TESTING=true

# Feature Toggle: Set to 'true' to enable Google/Mixpanel tracking
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Deployment Toggle: maintenance mode
NEXT_PUBLIC_MAINTENANCE_MODE=false