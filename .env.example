# 🔐 ContextMatic Environment Variables Configuration
# Copy this file to .env.local and fill in your actual credentials.
# Grouped by service for ease of manageability.

# === CORE INFRASTRUCTURE ===
# [REQUIRED] Supabase project URL for database and auth
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# [REQUIRED] Supabase anonymous key for client operations
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# [REQUIRED] Supabase service role key for backend admin operations
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === AUTHENTICATION ===
# [OPTIONAL] Clerk publishable key (if using Clerk instead of Supabase auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# [OPTIONAL] Clerk secret key
CLERK_SECRET_KEY=sk_test_...

# === AI PROVIDERS (Text & Analysis) ===
# [REQUIRED] Groq API key for fast inference
GROQ_API_KEY=gsk_...
# [REQUIRED] Gemini API key for advanced analysis and voice matching
GEMINI_API_KEY=AIzaSy...
# [REQUIRED] Public Gemini API key for client-side generation
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSy...
# [OPTIONAL] OpenAI API key for fallback operations
OPENAI_API_KEY=sk-proj-...

# === AI PROVIDERS (Image & Video) ===
# [REQUIRED] HuggingFace API key for fast image generation
HUGGINGFACE_API_KEY=hf_...
# [REQUIRED] Fal.ai API key for fast video rendering
FAL_KEY=...
# [OPTIONAL] Replicate API token for legacy model inference
REPLICATE_API_TOKEN=r8_...

# === INFRASTRUCTURE & CACHE ===
# [REQUIRED] Upstash Redis URL for rate limiting and state
UPSTASH_REDIS_REST_URL=https://...
# [REQUIRED] Upstash Redis token
UPSTASH_REDIS_REST_TOKEN=...
# [REQUIRED] Cron secret for scheduled tasks (generate random 32-char string)
CRON_SECRET=...

# === PAYMENTS (Razorpay & PayPal) ===
# [REQUIRED] Razorpay live key ID
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
# [REQUIRED] Razorpay live key secret
RAZORPAY_KEY_SECRET=...
# [REQUIRED] Razorpay webhook secret for verifying payment events
RAZORPAY_WEBHOOK_SECRET=...
# [OPTIONAL] PayPal client ID
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...
# [OPTIONAL] PayPal client secret
PAYPAL_CLIENT_SECRET=...
# [OPTIONAL] Stripe secret key
STRIPE_SECRET_KEY=sk_live_...
# [OPTIONAL] Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# === COMMUNICATION & SOCIAL ===
# [REQUIRED] Resend API key for outbound transactional emails
RESEND_API_KEY=re_...
# [REQUIRED] Ayrshare API key for social media posting
AYRSHARE_API_KEY=...

# === FEATURE FLAGS & ADMIN ===
# [OPTIONAL] Set to true to enable simulated payments without charging
NEXT_PUBLIC_ENABLE_PAYMENT_TESTING=false
# [OPTIONAL] Set to true to track user analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true
# [OPTIONAL] Set to true to track frontend errors
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
# [OPTIONAL] Set to true to display maintenance screen
NEXT_PUBLIC_MAINTENANCE_MODE=false
# [REQUIRED] Comma-separated list of admin emails
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# === DEPLOYMENT ===
# [REQUIRED] The production URL of the application
NEXT_PUBLIC_APP_URL=https://contextmatic.com
# [REQUIRED] Must be set to 'production' in live environment
NODE_ENV=production